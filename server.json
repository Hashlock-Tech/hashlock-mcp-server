{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Hashlock-Tech/hashlock",
  "title": "Hashlock — Intent Trading Protocol",
  "description": "Hashlock-Tech intent protocol — sealed-bid crypto swaps on Ethereum, Bitcoin, and SUI.",
  "websiteUrl": "https://hashlock.markets",
  "repository": {
    "url": "https://github.com/Hashlock-Tech/hashlock-mcp-server",
    "source": "github"
  },
  "version": "1.0.5",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "hashlock-mcp-server",
      "version": "1.0.5",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "HASHLOCK_API_URL",
          "description": "Hashlock API base URL",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "HASHLOCK_API_KEY",
          "description": "Your Hashlock API key for authentication",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://hashlock.markets/mcp"
    }
  ]
}
